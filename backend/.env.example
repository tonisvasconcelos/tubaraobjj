PORT=4000
NODE_ENV=development
# Database: use Neon (recommended) or any PostgreSQL. Neon connection string includes ?sslmode=require.
# Example (Neon): postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/tubarao_bjj
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@tubaraobjj.com
ADMIN_PASSWORD=change-me
UPLOAD_DIR=./uploads
API_PUBLIC_URL=http://localhost:4000
# Produção (Railway): inclua o site exato no browser, sem barra final, ex.:
# CORS_ORIGIN=https://www.tubaraobjj.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Analytics ingest hardening
ANALYTICS_INGEST_RATE_MAX=300
# Optional explicit allowlist (comma-separated). If empty, code allows tubaraobjj.com, vercel previews, localhost.
ANALYTICS_INGEST_ALLOWED_ORIGINS=
GEOIP_PROVIDER=ip-api
GEOIP_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tubaraobjj
# Public site URL used in payment return URLs
APP_PUBLIC_URL=https://www.tubaraobjj.com
# Payment provider config
PAYMENT_PROVIDER=mercadopago
MP_ACCESS_TOKEN=

# Resend email notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=
RESEND_REPLY_TO=
