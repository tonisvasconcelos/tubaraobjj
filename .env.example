# Frontend (Vite). Copy to .env and fill.
# API do backend (Node). Em produção (Vercel) use a URL pública do Railway, ex.:
# VITE_API_URL=https://api-production-a236.up.railway.app
VITE_API_URL=http://localhost:4000
# Base URL do site. Produção com domínio na raiz (www.tubaraobjj.com): /
# GitHub Pages (legado): /tubaraobjj/
# VITE_BASE_URL=/
# URL canônica do site (SEO: Open Graph, JSON-LD, canonical). Produção:
# VITE_SITE_URL=https://www.tubaraobjj.com
