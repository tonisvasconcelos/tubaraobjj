{
  "name": "tubarao-bjj-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "media:generate": "node scripts/generate-responsive-media.mjs",
    "media:video": "node scripts/generate-mobile-video.mjs",
    "seo:sitemap": "node scripts/generate-sitemap.mjs",
    "build": "npm run media:generate && npm run seo:sitemap && vite build && node scripts/run-prerender.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.14.2",
    "axios": "^1.6.2",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "swiper": "^11.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "ffmpeg-static": "^5.3.0",
    "postcss": "^8.4.32",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/team",
      "/addresses",
      "/store",
      "/horarios",
      "/aula-experimental"
    ],
    "skipThirdPartyRequests": true
  }
}
